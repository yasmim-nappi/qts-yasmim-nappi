DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Contatos</title>
</head>
<body>
<h1>Lista de Contatos</h1>
<form method="POST" action="/contatos">
<input type="text" name="n1" placeholder="Nome" required>
<input type="email" name="e1" placeholder="Email" required>
<button type="submit">Adicionar</button>
</form>
Servidor Express
<ul>
<% contatos.forEach((c, index) => { %>
<li>
<strong><%= c.nome %></strong> - <%= c.email %>
<a href="/contatos?delId=<%= index %>">[Remover]</a>
</li>
<% }) %>
</ul>
</body>
</html>